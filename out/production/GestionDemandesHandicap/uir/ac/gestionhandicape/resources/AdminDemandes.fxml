<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane
	xmlns="http://javafx.com/javafx/8"
	xmlns:fx="http://javafx.com/fxml/1"
	maxHeight="-Infinity"
	maxWidth="-Infinity"
	minHeight="-Infinity"
	minWidth="-Infinity"
	prefHeight="900.0"
	prefWidth="1100.0"
	fx:controller="uir.ac.gestionhandicape.controllers.AdminDemandesController">
	<left>
		<VBox
			prefHeight="900.0"
			prefWidth="220.0"
			style="-fx-background-color:#073566;">
			<children>
				<VBox
					alignment="CENTER"
					spacing="10.0"
					style="-fx-padding:30 20 20 20;">
					<children>
						<ImageView
							fitHeight="70.0"
							fitWidth="70.0"
							pickOnBounds="true"
							preserveRatio="true">
							<image>
								<Image url="@../img/UIR-logo.jpg"/>
							</image>
						</ImageView>
						<Text
							fill="#d0d71c"
							text="Espace Administrateur"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font
									name="DIN Condensed Bold"
									size="18.0" />
							</font>
						</Text>
						<Text
							fill="#ffffff"
							text="Gestion administrative"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font size="11.0"/>
							</font>
						</Text>
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					alignment="CENTER"
					spacing="6.0"
					style="-fx-padding:20 16 16 16;">
					<children>
						<Label
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:20px;-fx-font-weight:bold;-fx-background-radius:30;-fx-min-width:52;-fx-min-height:52;-fx-alignment:CENTER;"
							text="AD" />
						<Label
							style="-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-font-weight:bold;"
							text="Admin UIR" />
						<Label
							style="-fx-text-fill:#aaaaaa;-fx-font-size:11px;"
							text="Administrateur" />
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					spacing="4.0"
					style="-fx-padding:16 12 16 12;">
					<children>
						<Button
							fx:id="btnDashboard"
							onAction="#handleDashboard"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Tableau de bord" />
						<Button
							fx:id="btnDemandes"
							onAction="#handleDemandes"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Demandes" />
						<Button
							fx:id="btnReclamations"
							onAction="#handleReclamations"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Réclamations" />
						<Button
							fx:id="btnStats"
							onAction="#handleStats"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Statistiques" />
						<Button
							fx:id="btnArchives"
							onAction="#handleArchives"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Archivage" />
						<Button
							fx:id="btnComptes"
							onAction="#handleComptes"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Comptes" />
					</children>
				</VBox>
				<Region VBox.vgrow="ALWAYS"/>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox style="-fx-padding:16 12 24 12;">
					<children>
						<Button
							onAction="#handleLogout"
							prefHeight="42.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ff6b6b;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Déconnexion" />
					</children>
				</VBox>
			</children>
		</VBox>
	</left>
	<center>
		<VBox style="-fx-background-color:#f0f4f8;">
			<children>
				<HBox
					alignment="CENTER_LEFT"
					prefHeight="64.0"
					spacing="14.0"
					style="-fx-background-color:#ffffff;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),6,0,0,2);-fx-padding:0 24 0 24;">
					<children>
						<VBox
							alignment="CENTER_LEFT"
							HBox.hgrow="ALWAYS">
							<children>
								<Text
									fill="#073566"
									text="Gestion des demandes">
									<font>
										<Font
											name="DIN Condensed Bold"
											size="20.0" />
									</font>
								</Text>
								<Text
									fill="#aaaaaa"
									text="Traitement administratif des demandes">
									<font>
										<Font size="11.0"/>
									</font>
								</Text>
							</children>
						</VBox>
						<TextField
							fx:id="searchField"
							prefHeight="36.0"
							prefWidth="260.0"
							promptText="Rechercher..."
							style="-fx-background-color:#f0f4f8;-fx-border-color:transparent;-fx-background-radius:20;-fx-padding:0 14;-fx-font-size:12px;" />
					</children>
				</HBox>
				<ScrollPane
					fitToWidth="true"
					VBox.vgrow="ALWAYS"
					style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
					<content>
						<VBox
							spacing="20.0"
							fillWidth="true"
							style="-fx-padding:24 28 28 28;">
							<children>
								<HBox spacing="14.0">
									<children>
										<VBox
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:18;">
											<children>
												<Label
													text="Demandes totales"
													style="-fx-text-fill:#888888;" />
												<Label
													text="24"
													style="-fx-text-fill:#073566;-fx-font-size:26px;-fx-font-weight:bold;" />
											</children>
										</VBox>
										<VBox
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:18;">
											<children>
												<Label
													text="En attente"
													style="-fx-text-fill:#888888;" />
												<Label
													text="8"
													style="-fx-text-fill:#e67e22;-fx-font-size:26px;-fx-font-weight:bold;" />
											</children>
										</VBox>
										<VBox
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:18;">
											<children>
												<Label
													text="Acceptées"
													style="-fx-text-fill:#888888;" />
												<Label
													text="12"
													style="-fx-text-fill:#27ae60;-fx-font-size:26px;-fx-font-weight:bold;" />
											</children>
										</VBox>
										<VBox
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:18;">
											<children>
												<Label
													text="Refusées"
													style="-fx-text-fill:#888888;" />
												<Label
													text="4"
													style="-fx-text-fill:#e74c3c;-fx-font-size:26px;-fx-font-weight:bold;" />
											</children>
										</VBox>
									</children>
								</HBox>
								<VBox
									spacing="14.0"
									style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
									<children>
										<HBox
											alignment="CENTER_LEFT"
											spacing="8.0">
											<children>
												<Label
													HBox.hgrow="ALWAYS"
													text="Gestion des demandes"
													style="-fx-text-fill:#073566;-fx-font-size:15px;-fx-font-weight:bold;" />
												<ComboBox
													fx:id="filtreStatut"
													promptText="Statut"
													prefWidth="140.0" />
												<ComboBox
													fx:id="filtreType"
													promptText="Type"
													prefWidth="160.0" />
											</children>
										</HBox>
										<Separator/>
										<TableView
											fx:id="adminDemandesTable"
											prefHeight="460.0">
											<columns>
												<TableColumn
													fx:id="colRef"
													text="Réf."
													prefWidth="80.0" />
												<TableColumn
													fx:id="colEtudiant"
													text="Étudiant"
													prefWidth="150.0" />
												<TableColumn
													fx:id="colType"
													text="Type"
													prefWidth="150.0" />
												<TableColumn
													fx:id="colDate"
													text="Date"
													prefWidth="110.0" />
												<TableColumn
													fx:id="colPriorite"
													text="Priorité"
													prefWidth="90.0" />
												<TableColumn
													fx:id="colStatut"
													text="Statut"
													prefWidth="100.0" />
												<TableColumn
													fx:id="colActions"
													text="Actions"
													prefWidth="120.0" />
											</columns>
										</TableView>
										<HBox
											alignment="CENTER_RIGHT"
											spacing="10.0">
											<children>
												<Button
													onAction="#handleAccept"
													text="Accepter"
													style="-fx-background-color:#27ae60;-fx-text-fill:white;-fx-font-weight:bold;" />
												<Button
													onAction="#handleReject"
													text="Refuser"
													style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;" />
												<Button
													onAction="#handlePending"
													text="En attente"
													style="-fx-background-color:#e67e22;-fx-text-fill:white;-fx-font-weight:bold;" />
											</children>
										</HBox>
									</children>
								</VBox>
							</children>
						</VBox>
					</content>
				</ScrollPane>
			</children>
		</VBox>
	</center>
</BorderPane>
