<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane
	xmlns="http://javafx.com/javafx/8"
	xmlns:fx="http://javafx.com/fxml/1"
	maxHeight="-Infinity"
	maxWidth="-Infinity"
	minHeight="-Infinity"
	minWidth="-Infinity"
	prefHeight="900.0"
	prefWidth="1100.0"
	fx:controller="uir.ac.gestionhandicape.controllers.MesDemandesController">
	<left>
		<VBox
			prefHeight="900.0"
			prefWidth="220.0"
			style="-fx-background-color:#073566;">
			<children>
				<VBox
					alignment="CENTER"
					spacing="10.0"
					style="-fx-padding:30 20 20 20;">
					<children>
						<ImageView
							fitHeight="70.0"
							fitWidth="70.0"
							pickOnBounds="true"
							preserveRatio="true">
							<image>
								<Image url="@../img/UIR-logo.jpg"/>
							</image>
						</ImageView>
						<Text
							fill="#d0d71c"
							text="Espace Étudiant"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font
									name="DIN Condensed Bold"
									size="18.0" />
							</font>
						</Text>
						<Text
							fill="#ffffff"
							text="Gestion demandes &amp; réclamations"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font size="11.0"/>
							</font>
						</Text>
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					alignment="CENTER"
					spacing="6.0"
					style="-fx-padding:20 16 16 16;">
					<children>
						<Label
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:20px;-fx-font-weight:bold;-fx-background-radius:30;-fx-min-width:52;-fx-min-height:52;-fx-alignment:CENTER;"
							text="A" />
						<Label
							style="-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-font-weight:bold;"
							text="Amine Benali" />
						<Label
							style="-fx-text-fill:#aaaaaa;-fx-font-size:11px;"
							text="N° 20230001" />
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					spacing="4.0"
					style="-fx-padding:16 12 16 12;">
					<children>
						<Button
							fx:id="btnDashboard"
							onAction="#handleDashboard"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Tableau de bord" />
						<Button
							fx:id="btnDemandes"
							onAction="#handleDemandes"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Mes demandes" />
						<Button
							fx:id="btnNewDemande"
							onAction="#handleNouvelleDemande"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Nouvelle demande" />
						<Button
							fx:id="btnReclamations"
							onAction="#handleReclamations"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Mes réclamations" />
						<Button
							fx:id="btnNewReclamation"
							onAction="#handleNouvelleReclamation"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Nouvelle réclamation" />
						<Button
							fx:id="btnProfil"
							onAction="#handleProfil"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Mon profil" />
					</children>
				</VBox>
				<Region VBox.vgrow="ALWAYS"/>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox style="-fx-padding:16 12 24 12;">
					<children>
						<Button
							onAction="#handleLogout"
							prefHeight="42.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ff6b6b;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Déconnexion" />
					</children>
				</VBox>
			</children>
		</VBox>
	</left>
	<center>
		<VBox style="-fx-background-color:#f0f4f8;">
			<children>
				<HBox
					alignment="CENTER_LEFT"
					prefHeight="64.0"
					spacing="14.0"
					style="-fx-background-color:#ffffff;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),6,0,0,2);-fx-padding:0 24 0 24;">
					<children>
						<VBox
							alignment="CENTER_LEFT"
							HBox.hgrow="ALWAYS">
							<children>
								<Text
									fill="#073566"
									text="Mes demandes">
									<font>
										<Font
											name="DIN Condensed Bold"
											size="20.0" />
									</font>
								</Text>
								<Text
									fill="#aaaaaa"
									text="Suivi de vos demandes d’aménagement">
									<font>
										<Font size="11.0"/>
									</font>
								</Text>
							</children>
						</VBox>
						<TextField
							fx:id="searchField"
							prefHeight="36.0"
							prefWidth="260.0"
							promptText="Rechercher..."
							style="-fx-background-color:#f0f4f8;-fx-border-color:transparent;-fx-background-radius:20;-fx-padding:0 14;-fx-font-size:12px;" />
						<Button
							onAction="#handleNouvelleDemande"
							prefHeight="36.0"
							style="-fx-background-color:#073566;-fx-text-fill:#ffffff;-fx-font-size:12px;-fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;-fx-padding:0 18;"
							text="+ Nouvelle demande" />
					</children>
				</HBox>
				<ScrollPane
					fitToWidth="true"
					VBox.vgrow="ALWAYS"
					style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
					<content>
						<VBox
							spacing="20.0"
							fillWidth="true"
							style="-fx-padding:24 28 28 28;">
							<children>
								<HBox spacing="14.0">
									<children>
										<VBox
											alignment="CENTER_LEFT"
											spacing="4.0"
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
											<children>
												<Label
													style="-fx-text-fill:#888888;-fx-font-size:11px;"
													text="Total demandes" />
												<Label
													fx:id="statTotal"
													style="-fx-text-fill:#073566;-fx-font-size:26px;-fx-font-weight:bold;"
													text="4" />
											</children>
										</VBox>
										<VBox
											alignment="CENTER_LEFT"
											spacing="4.0"
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
											<children>
												<Label
													style="-fx-text-fill:#888888;-fx-font-size:11px;"
													text="En attente" />
												<Label
													fx:id="statAttente"
													style="-fx-text-fill:#e67e22;-fx-font-size:26px;-fx-font-weight:bold;"
													text="1" />
											</children>
										</VBox>
										<VBox
											alignment="CENTER_LEFT"
											spacing="4.0"
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
											<children>
												<Label
													style="-fx-text-fill:#888888;-fx-font-size:11px;"
													text="Acceptées" />
												<Label
													fx:id="statAcceptees"
													style="-fx-text-fill:#27ae60;-fx-font-size:26px;-fx-font-weight:bold;"
													text="2" />
											</children>
										</VBox>
										<VBox
											alignment="CENTER_LEFT"
											spacing="4.0"
											HBox.hgrow="ALWAYS"
											style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
											<children>
												<Label
													style="-fx-text-fill:#888888;-fx-font-size:11px;"
													text="Refusées" />
												<Label
													fx:id="statRefusees"
													style="-fx-text-fill:#e74c3c;-fx-font-size:26px;-fx-font-weight:bold;"
													text="1" />
											</children>
										</VBox>
									</children>
								</HBox>
								<VBox
									spacing="14.0"
									style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
									<children>
										<HBox
											alignment="CENTER_LEFT"
											spacing="8.0">
											<children>
												<Label
													HBox.hgrow="ALWAYS"
													style="-fx-text-fill:#073566;-fx-font-size:15px;-fx-font-weight:bold;"
													text="Liste des demandes" />
												<ComboBox
													fx:id="filtreStatut"
													prefHeight="32.0"
													prefWidth="150.0"
													promptText="Statut"
													style="-fx-background-color:#f0f4f8;-fx-background-radius:6;" />
												<ComboBox
													fx:id="filtreType"
													prefHeight="32.0"
													prefWidth="170.0"
													promptText="Type demande"
													style="-fx-background-color:#f0f4f8;-fx-background-radius:6;" />
											</children>
										</HBox>
										<Separator/>
										<TableView
											fx:id="demandesTable"
											prefHeight="420.0"
											style="-fx-background-color:transparent;-fx-border-color:transparent;">
											<columns>
												<TableColumn
													fx:id="colRef"
													prefWidth="90.0"
													text="Réf." />
												<TableColumn
													fx:id="colType"
													prefWidth="170.0"
													text="Type" />
												<TableColumn
													fx:id="colObjet"
													prefWidth="210.0"
													text="Objet" />
												<TableColumn
													fx:id="colDate"
													prefWidth="130.0"
													text="Date" />
												<TableColumn
													fx:id="colStatut"
													prefWidth="120.0"
													text="Statut" />
												<TableColumn
													fx:id="colActions"
													prefWidth="100.0"
													text="Actions" />
											</columns>
										</TableView>
									</children>
								</VBox>
							</children>
						</VBox>
					</content>
				</ScrollPane>
			</children>
		</VBox>
	</center>
</BorderPane>
