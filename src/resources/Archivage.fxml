<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane
	xmlns="http://javafx.com/javafx/8"
	xmlns:fx="http://javafx.com/fxml/1"
	maxHeight="-Infinity"
	maxWidth="-Infinity"
	minHeight="-Infinity"
	minWidth="-Infinity"
	prefHeight="900.0"
	prefWidth="1100.0"
	fx:controller="uir.ac.gestionhandicape.controllers.ArchivageController">
	<left>
		<VBox
			prefHeight="900.0"
			prefWidth="220.0"
			style="-fx-background-color:#073566;">
			<children>
				<VBox
					alignment="CENTER"
					spacing="10.0"
					style="-fx-padding:30 20 20 20;">
					<children>
						<ImageView
							fitHeight="70.0"
							fitWidth="70.0"
							pickOnBounds="true"
							preserveRatio="true">
							<image>
								<Image url="@../img/UIR-logo.jpg"/>
							</image>
						</ImageView>
						<Text
							fill="#d0d71c"
							text="Espace Administrateur"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font
									name="DIN Condensed Bold"
									size="18.0" />
							</font>
						</Text>
						<Text
							fill="#ffffff"
							text="Gestion administrative"
							textAlignment="CENTER"
							wrappingWidth="170.0">
							<font>
								<Font size="11.0"/>
							</font>
						</Text>
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					alignment="CENTER"
					spacing="6.0"
					style="-fx-padding:20 16 16 16;">
					<children>
						<Label
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:20px;-fx-font-weight:bold;-fx-background-radius:30;-fx-min-width:52;-fx-min-height:52;-fx-alignment:CENTER;"
							text="AD" />
						<Label
							style="-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-font-weight:bold;"
							text="Admin UIR" />
						<Label
							style="-fx-text-fill:#aaaaaa;-fx-font-size:11px;"
							text="Administrateur" />
					</children>
				</VBox>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox
					spacing="4.0"
					style="-fx-padding:16 12 16 12;">
					<children>
						<Button
							fx:id="btnDashboard"
							onAction="#handleDashboard"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Tableau de bord" />
						<Button
							fx:id="btnDemandes"
							onAction="#handleDemandes"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Demandes" />
						<Button
							fx:id="btnReclamations"
							onAction="#handleReclamations"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Réclamations" />
						<Button
							fx:id="btnStats"
							onAction="#handleStats"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Statistiques" />
						<Button
							fx:id="btnArchives"
							onAction="#handleArchives"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:#d0d71c;-fx-text-fill:#073566;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Archivage" />
						<Button
							fx:id="btnComptes"
							onAction="#handleComptes"
							prefHeight="40.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ffffff;-fx-font-size:13px;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Comptes" />
					</children>
				</VBox>
				<Region VBox.vgrow="ALWAYS"/>
				<Separator style="-fx-background-color:#1a4a7a;"/>
				<VBox style="-fx-padding:16 12 24 12;">
					<children>
						<Button
							onAction="#handleLogout"
							prefHeight="42.0"
							prefWidth="196.0"
							style="-fx-background-color:transparent;-fx-text-fill:#ff6b6b;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:8;-fx-alignment:CENTER-LEFT;-fx-cursor:hand;-fx-padding:0 0 0 14;"
							text="Déconnexion" />
					</children>
				</VBox>
			</children>
		</VBox>
	</left>
	<center>
		<VBox style="-fx-background-color:#f0f4f8;">
			<children>
				<HBox
					alignment="CENTER_LEFT"
					prefHeight="64.0"
					spacing="14.0"
					style="-fx-background-color:#ffffff;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),6,0,0,2);-fx-padding:0 24 0 24;">
					<children>
						<VBox
							alignment="CENTER_LEFT"
							HBox.hgrow="ALWAYS">
							<children>
								<Text
									fill="#073566"
									text="Archivage">
									<font>
										<Font
											name="DIN Condensed Bold"
											size="20.0" />
									</font>
								</Text>
								<Text
									fill="#aaaaaa"
									text="Historique complet et recherche multicritère">
									<font>
										<Font size="11.0"/>
									</font>
								</Text>
							</children>
						</VBox>
						<TextField
							fx:id="searchField"
							prefHeight="36.0"
							prefWidth="260.0"
							promptText="Rechercher..."
							style="-fx-background-color:#f0f4f8;-fx-border-color:transparent;-fx-background-radius:20;-fx-padding:0 14;-fx-font-size:12px;" />
					</children>
				</HBox>
				<ScrollPane
					fitToWidth="true"
					style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;"
					VBox.vgrow="ALWAYS">
					<content>
						<VBox
							fillWidth="true"
							spacing="20.0"
							style="-fx-padding:24 28 28 28;">
							<children>
								<VBox
									spacing="16.0"
									style="-fx-background-color:#ffffff;-fx-background-radius:12;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20 22;">
									<children>
										<HBox
											alignment="CENTER_LEFT"
											spacing="10.0">
											<children>
												<Label
													style="-fx-text-fill:#073566;-fx-font-size:15px;-fx-font-weight:bold;"
													text="Recherche multicritère"
													HBox.hgrow="ALWAYS" />
												<DatePicker
													fx:id="dateDebutPicker"
													promptText="Date début" />
												<DatePicker
													fx:id="dateFinPicker"
													promptText="Date fin" />
												<ComboBox
													fx:id="typeArchiveCombo"
													prefWidth="130.0"
													promptText="Type" />
												<Button
													onAction="#handleSearch"
													style="-fx-background-color:#073566;-fx-text-fill:white;-fx-font-weight:bold;"
													text="Rechercher" />
											</children>
										</HBox>
										<Separator/>
										<TableView
											fx:id="archivesTable"
											prefHeight="480.0">
											<columns>
												<TableColumn
													fx:id="colId"
													prefWidth="70.0"
													text="ID" />
												<TableColumn
													fx:id="colType"
													prefWidth="140.0"
													text="Type" />
												<TableColumn
													fx:id="colElement"
													prefWidth="180.0"
													text="Élément" />
												<TableColumn
													fx:id="colDate"
													prefWidth="130.0"
													text="Date d'archivage" />
												<TableColumn
													fx:id="colMotif"
													prefWidth="220.0"
													text="Motif" />
												<TableColumn
													fx:id="colActions"
													prefWidth="120.0"
													text="Actions" />
											</columns>
										</TableView>
										<HBox
											alignment="CENTER_RIGHT"
											spacing="10.0">
											<children>
												<Button
													onAction="#handleRestore"
													style="-fx-background-color:#27ae60;-fx-text-fill:white;-fx-font-weight:bold;"
													text="Restaurer" />
												<Button
													onAction="#handleDeleteArchive"
													style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;"
													text="Supprimer" />
												<Button
													onAction="#handleExportArchives"
													style="-fx-background-color:#073566;-fx-text-fill:white;-fx-font-weight:bold;"
													text="Exporter" />
											</children>
										</HBox>
									</children>
								</VBox>
							</children>
						</VBox>
					</content>
				</ScrollPane>
			</children>
		</VBox>
	</center>
</BorderPane>
