<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<BorderPane
	xmlns="http://javafx.com/javafx/8"
	xmlns:fx="http://javafx.com/fxml/1"
	maxHeight="-Infinity"
	maxWidth="-Infinity"
	minHeight="-Infinity"
	minWidth="-Infinity"
	prefHeight="450.0"
	prefWidth="700.0"
	fx:controller="uir.ac.gestionhandicape.controllers.LoginController">
	<left>
		<AnchorPane
			prefHeight="450.0"
			prefWidth="260.0"
			style="-fx-background-color:#073566;"
			BorderPane.alignment="CENTER">
			<children>
				<VBox
					alignment="CENTER"
					layoutX="0.0"
					layoutY="0.0"
					prefHeight="450.0"
					prefWidth="260.0"
					spacing="16.0">
					<padding>
						<Insets
							bottom="40.0"
							left="20.0"
							right="20.0"
							top="40.0" />
					</padding>
					<children>
						<ImageView
							fitHeight="130.0"
							fitWidth="130.0"
							pickOnBounds="true"
							preserveRatio="true">
							<image>
								<Image url="@../img/UIR-logo.jpg"/>
							</image>
						</ImageView>
						<Separator>
							<padding>
								<Insets
									bottom="8.0"
									top="8.0" />
							</padding>
						</Separator>
						<Text
							fill="#d0d71c"
							fontSmoothingType="LCD"
							text="Plateforme officielle de traitement des réclamations des étudiants en situation de handicap."
							textAlignment="CENTER"
							wrappingWidth="200.0">
							<font>
								<Font
									name="DIN Condensed Bold"
									size="16.0" />
							</font>
						</Text>
					</children>
				</VBox>
			</children>
		</AnchorPane>
	</left>
	<center>
		<AnchorPane
			prefHeight="450.0"
			prefWidth="440.0"
			style="-fx-background-color:#f7f9f9;"
			BorderPane.alignment="CENTER">
			<children>
				<VBox
					alignment="CENTER"
					layoutX="0.0"
					layoutY="0.0"
					prefHeight="450.0"
					prefWidth="440.0"
					spacing="18.0">
					<padding>
						<Insets
							bottom="50.0"
							left="60.0"
							right="60.0"
							top="50.0" />
					</padding>
					<children>
						<Text
							fill="#073566"
							text="Accédez à votre compte"
							textAlignment="CENTER"
							wrappingWidth="320.0">
							<font>
								<Font
									name="DIN Condensed Bold"
									size="28.0" />
							</font>
						</Text>
						<VBox spacing="6.0">
							<children>
								<Label
									style="-fx-font-size:13px;-fx-text-fill:#073566;-fx-font-weight:bold;"
									text="Adresse e-mail" />
								<TextField
									fx:id="emailField"
									prefWidth="320.0"
									promptText="exemple@uir.ac.ma"
									style="-fx-background-color:#ffffff;-fx-border-color:#cccccc;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:10 14;-fx-font-size:13px;" />
							</children>
						</VBox>
						<VBox spacing="6.0">
							<children>
								<Label
									style="-fx-font-size:13px;-fx-text-fill:#073566;-fx-font-weight:bold;"
									text="Mot de passe" />
								<PasswordField
									fx:id="passwordField"
									prefWidth="320.0"
									promptText="••••••••"
									style="-fx-background-color:#ffffff;-fx-border-color:#cccccc;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:10 14;-fx-font-size:13px;" />
							</children>
						</VBox>
						<HBox
							alignment="CENTER_RIGHT"
							prefWidth="320.0">
							<children>
								<Label
									style="-fx-font-size:12px;-fx-text-fill:#d0d71c;-fx-cursor:hand;"
									text="Mot de passe oublié "
									underline="true" />
							</children>
						</HBox>
						<Button
							fx:id="loginButton"
							onAction="#handleLogin"
							prefHeight="42.0"
							prefWidth="320.0"
							style="-fx-background-color:#073566;-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;"
							text="Se connecter" />
						<HBox
							alignment="CENTER"
							spacing="10.0">
							<children>
								<Separator prefWidth="130.0"/>
								<Label
									style="-fx-text-fill:#aaaaaa;-fx-font-size:12px;"
									text="ou" />
								<Separator prefWidth="130.0"/>
							</children>
						</HBox>
						<HBox
							alignment="CENTER"
							spacing="4.0">
							<children>
								<Label
									style="-fx-font-size:12px;-fx-text-fill:#555555;"
									text="Pas encore de compte ?" />
								<Label
									onMouseClicked="#handleGoToRegister"
									pickOnBounds="false"
									style="-fx-font-size:12px;-fx-text-fill:#073566;-fx-font-weight:bold;-fx-cursor:hand;"
									text="S'inscrire"
									underline="true" />
							</children>
						</HBox>
					</children>
				</VBox>
			</children>
		</AnchorPane>
	</center>
</BorderPane>
